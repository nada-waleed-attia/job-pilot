# JobPilot Backend Environment Variables

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (for production)
DATABASE_URL=postgresql://username:password@localhost:5432/jobpilot_db

# Redis (for caching and task queue)
REDIS_URL=redis://localhost:6379

# Job APIs
ADZUNA_API_KEY=your-adzuna-api-key
INDEED_API_KEY=your-indeed-api-key
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# File Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=jobpilot-files
AWS_REGION=us-east-1

# Application Settings
DEBUG=True
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:5500"]
MAX_FILE_SIZE=5242880  # 5MB in bytes

# Automation Settings
AUTO_APPLY_ENABLED=True
AUTO_APPLY_DELAY_MIN=30
AUTO_APPLY_DELAY_MAX=120

# Browser Automation
SELENIUM_DRIVER_PATH=./drivers/chromedriver
BROWSER_HEADLESS=True
